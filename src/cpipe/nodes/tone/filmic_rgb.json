{
  "$schema": "https://schemas.cpipe.dev/node/v0.2.json",
  "id": "com.cpipe.tone.filmic_rgb",
  "version": "1.0.0",
  "label": "Filmic RGB Tone",
  "category": "tone",
  "doc": "Fixed filmic-RGB-style global tone curve for scene-linear RGBA.",
  "ports": [
    {
      "name": "rgb",
      "kind": "in",
      "caps": {
        "buffer_kind": "Image2D",
        "channels": ["rgba"],
        "precision": ["f16"]
      },
      "cardinality": "single",
      "metadata": {
        "requires_steps_applied": ["denoise.wavelet_bayes_shrink"]
      }
    },
    {
      "name": "rgb",
      "kind": "out",
      "caps": {
        "buffer_kind": "Image2D",
        "channels": ["rgba"],
        "precision": ["f16"]
      },
      "cardinality": "single",
      "metadata": {
        "inherits_from": "rgb",
        "sets_steps_applied": ["tone.filmic_rgb"]
      }
    }
  ],
  "params": [
    {
      "name": "ev",
      "type": "number",
      "range": {
        "min": -2,
        "max": 2
      },
      "default": 0
    },
    {
      "name": "contrast",
      "type": "number",
      "range": {
        "min": 0.5,
        "max": 2
      },
      "default": 1
    },
    {
      "name": "saturation",
      "type": "number",
      "range": {
        "min": 0,
        "max": 2
      },
      "default": 1
    },
    {
      "name": "highlights",
      "type": "number",
      "range": {
        "min": 0,
        "max": 2
      },
      "default": 1
    },
    {
      "name": "shadows",
      "type": "number",
      "range": {
        "min": 0,
        "max": 2
      },
      "default": 1
    }
  ],
  "compute": {
    "device": "CPU",
    "engine": "Halide",
    "in_pixel_bytes": 8,
    "out_pixel_bytes": 8,
    "scratch_pixel_bytes": 0,
    "halide_aot": ["tone_filmic_rgb"]
  },
  "color": {
    "input_role": "scene_linear_rec2020",
    "output_role": "scene_linear_rec2020",
    "respects_chromaticity": true
  }
}
