{
  "$schema": "https://schemas.cpipe.dev/node/v0.1.json",
  "id": "com.cpipe.colormatrix.dng_to_working",
  "version": "1.0.0",
  "label": "DNG Color Matrix",
  "category": "color",
  "doc": "Maps white-balanced camera RGB through DNG ColorMatrix1 into linear Rec.2020 D65.",
  "ports": [
    {
      "name": "rgb",
      "kind": "in",
      "caps": {
        "buffer_kind": "Image2D",
        "channels": ["rgba"],
        "precision": ["f16"]
      },
      "cardinality": "single",
      "metadata": {
        "requires_steps_applied": ["white_balance"],
        "requires_fields": ["calibration.color_matrix1", "cs_role"]
      }
    },
    {
      "name": "rgb",
      "kind": "out",
      "caps": {
        "buffer_kind": "Image2D",
        "channels": ["rgba"],
        "precision": ["f16"]
      },
      "cardinality": "single",
      "metadata": {
        "inherits_from": "rgb",
        "sets_steps_applied": ["color_matrix"],
        "writes_fields": ["cs_role"]
      }
    }
  ],
  "params": [],
  "compute": {
    "device": "CPU",
    "engine": "Host",
    "in_pixel_bytes": 8,
    "out_pixel_bytes": 8,
    "scratch_pixel_bytes": 0
  },
  "color": {
    "input_role": "raw_camera",
    "output_role": "scene_linear_rec2020",
    "respects_chromaticity": true
  }
}
