{
    "$schema": "https://schemas.cpipe.dev/node/v0.1.json",
    "id": "com.cpipe.builtin.passthrough",
    "version": "1.0.0",
    "label": "Passthrough",
    "category": "utility",
    "doc": "Copies an RGBA8 image through the Halide AOT compute path.",
    "ports": [
        {
            "name": "in",
            "kind": "in",
            "caps": {
                "buffer_kind": "Image2D",
                "formats": ["R8G8B8A8_UNORM"],
                "channels": ["rgba"],
                "precision": ["uint8"]
            },
            "cardinality": "single"
        },
        {
            "name": "out",
            "kind": "out",
            "caps": {
                "buffer_kind": "Image2D",
                "formats": ["R8G8B8A8_UNORM"],
                "channels": ["rgba"],
                "precision": ["uint8"]
            },
            "cardinality": "single"
        }
    ],
    "params": [],
    "compute": {
        "device": "CPU",
        "engine": "Halide",
        "halide_aot": ["passthrough_copy"],
        "in_pixel_bytes": 4,
        "out_pixel_bytes": 4,
        "scratch_pixel_bytes": 0
    },
    "color": {
        "input_role": "any",
        "output_role": "any",
        "respects_chromaticity": true
    },
    "test": {
        "golden_pairs": []
    }
}
