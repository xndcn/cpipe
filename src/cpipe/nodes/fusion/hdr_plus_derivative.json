{
  "$schema": "https://schemas.cpipe.dev/node/v0.2.json",
  "id": "com.cpipe.fusion.hdr_plus_derivative",
  "version": "1.0.0",
  "label": "HDR+ Derivative Fusion",
  "category": "fusion",
  "doc": "Registered passthrough placeholder for the future HDR+ derivative burst fusion node.",
  "ports": [
    {
      "name": "ref",
      "kind": "in",
      "caps": {
        "buffer_kind": "Image2D",
        "channels": ["r"],
        "precision": ["u16"]
      },
      "cardinality": "single"
    },
    {
      "name": "frame",
      "kind": "in",
      "caps": {
        "buffer_kind": "Image2D",
        "channels": ["r"],
        "precision": ["u16"]
      },
      "cardinality": "single"
    },
    {
      "name": "fused",
      "kind": "out",
      "caps": {
        "buffer_kind": "Image2D",
        "channels": ["r"],
        "precision": ["u16"]
      },
      "cardinality": "single",
      "metadata": {
        "inherits_from": "ref",
        "sets_steps_applied": ["burst_fusion_stub"]
      }
    }
  ],
  "params": [],
  "compute": {
    "device": "CPU",
    "engine": "Host",
    "in_pixel_bytes": 2,
    "out_pixel_bytes": 2,
    "scratch_pixel_bytes": 0
  },
  "color": {
    "input_role": "raw_camera",
    "output_role": "raw_camera",
    "respects_chromaticity": false
  }
}
