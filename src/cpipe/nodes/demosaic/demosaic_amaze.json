{
  "$schema": "https://schemas.cpipe.dev/node/v0.1.json",
  "id": "com.cpipe.demosaic.amaze",
  "version": "1.0.0",
  "label": "AMaZE Demosaic",
  "category": "raw",
  "doc": "Demosaics Bayer data with AMaZE-style anti-aliasing and zipper reduction.",
  "ports": [
    {
      "name": "bayer",
      "kind": "in",
      "caps": {
        "buffer_kind": "Image2D",
        "channels": ["r"],
        "precision": ["f32"]
      },
      "cardinality": "single",
      "metadata": {
        "requires_steps_applied": ["black_white_scaling"],
        "requires_fields": ["calibration.cfa"]
      }
    },
    {
      "name": "rgba",
      "kind": "out",
      "caps": {
        "buffer_kind": "Image2D",
        "channels": ["rgba"],
        "precision": ["f16"]
      },
      "cardinality": "single",
      "metadata": {
        "inherits_from": "bayer",
        "clears_fields": ["calibration.cfa"],
        "sets_steps_applied": ["demosaic"]
      }
    }
  ],
  "params": [],
  "compute": {
    "device": "CPU",
    "engine": "Halide",
    "halide_aot": ["demosaic_amaze"],
    "in_pixel_bytes": 4,
    "out_pixel_bytes": 8,
    "scratch_pixel_bytes": 0
  },
  "color": {
    "input_role": "raw_camera",
    "output_role": "raw_camera",
    "respects_chromaticity": false
  }
}
