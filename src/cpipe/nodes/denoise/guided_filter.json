{
  "$schema": "https://schemas.cpipe.dev/node/v0.2.json",
  "id": "com.cpipe.denoise.guided_filter",
  "version": "1.0.0",
  "label": "Guided Filter Denoise",
  "category": "denoise",
  "doc": "Fast edge-preserving guided-filter denoise for scene-linear RGBA.",
  "ports": [
    {
      "name": "rgb",
      "kind": "in",
      "caps": {
        "buffer_kind": "Image2D",
        "channels": ["rgba"],
        "precision": ["f16"]
      },
      "cardinality": "single",
      "metadata": {
        "requires_steps_applied": ["color_matrix"]
      }
    },
    {
      "name": "rgb",
      "kind": "out",
      "caps": {
        "buffer_kind": "Image2D",
        "channels": ["rgba"],
        "precision": ["f16"]
      },
      "cardinality": "single",
      "metadata": {
        "inherits_from": "rgb",
        "sets_steps_applied": ["denoise.guided_filter"]
      }
    }
  ],
  "params": [
    {
      "name": "radius",
      "type": "number",
      "range": {
        "min": 1,
        "max": 32
      },
      "default": 1
    },
    {
      "name": "eps",
      "type": "number",
      "range": {
        "min": 0.00001,
        "max": 0.1
      },
      "default": 0.015
    }
  ],
  "compute": {
    "device": "CPU",
    "engine": "Halide",
    "in_pixel_bytes": 8,
    "out_pixel_bytes": 8,
    "scratch_pixel_bytes": 0,
    "halide_aot": ["denoise_guided_filter"]
  },
  "color": {
    "input_role": "scene_linear_rec2020",
    "output_role": "scene_linear_rec2020",
    "respects_chromaticity": true
  }
}
