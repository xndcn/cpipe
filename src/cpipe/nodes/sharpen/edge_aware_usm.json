{
  "$schema": "https://schemas.cpipe.dev/node/v0.2.json",
  "id": "com.cpipe.sharpen.edge_aware_usm",
  "version": "1.0.0",
  "label": "Edge-aware USM",
  "category": "sharpen",
  "doc": "Guided-filter unsharp mask for scene-linear RGBA.",
  "ports": [
    {
      "name": "rgb",
      "kind": "in",
      "caps": {
        "buffer_kind": "Image2D",
        "channels": ["rgba"],
        "precision": ["f16"]
      },
      "cardinality": "single",
      "metadata": {
        "requires_steps_applied": ["color.3d_lut"]
      }
    },
    {
      "name": "rgb",
      "kind": "out",
      "caps": {
        "buffer_kind": "Image2D",
        "channels": ["rgba"],
        "precision": ["f16"]
      },
      "cardinality": "single",
      "metadata": {
        "inherits_from": "rgb",
        "sets_steps_applied": ["sharpen.edge_aware_usm"]
      }
    }
  ],
  "params": [
    {
      "name": "strength",
      "type": "number",
      "range": {
        "min": 0,
        "max": 2
      },
      "default": 0.75
    },
    {
      "name": "radius",
      "type": "number",
      "range": {
        "min": 1,
        "max": 32
      },
      "default": 1
    },
    {
      "name": "threshold",
      "type": "number",
      "range": {
        "min": 0,
        "max": 0.1
      },
      "default": 0
    }
  ],
  "compute": {
    "device": "CPU",
    "engine": "Halide",
    "in_pixel_bytes": 8,
    "out_pixel_bytes": 8,
    "scratch_pixel_bytes": 0,
    "halide_aot": ["sharpen_edge_aware_usm"]
  },
  "color": {
    "input_role": "scene_linear_rec2020",
    "output_role": "scene_linear_rec2020",
    "respects_chromaticity": true
  }
}
