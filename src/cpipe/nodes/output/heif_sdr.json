{
  "$schema": "https://schemas.cpipe.dev/node/v0.1.json",
  "id": "com.cpipe.output.heif_sdr",
  "version": "1.0.0",
  "label": "HEIF SDR Output",
  "category": "output",
  "doc": "Writes linear Rec.2020 D65 FP16 RGBA input as SDR sRGB HEIF.",
  "ports": [
    {
      "name": "rgb",
      "kind": "in",
      "caps": {
        "buffer_kind": "Image2D",
        "channels": ["rgba"],
        "precision": ["f16"]
      },
      "cardinality": "single",
      "metadata": {
        "requires_steps_applied": ["color_matrix"],
        "requires_fields": ["cs_role"]
      }
    }
  ],
  "params": [
    {
      "name": "path",
      "type": "string",
      "required": true
    }
  ],
  "compute": {
    "device": "CPU",
    "engine": "Host",
    "in_pixel_bytes": 8,
    "out_pixel_bytes": 0,
    "scratch_pixel_bytes": 0
  },
  "color": {
    "input_role": "scene_linear_rec2020",
    "output_role": "any",
    "respects_chromaticity": true
  }
}
