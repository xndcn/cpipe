{
  "$schema": "https://schemas.cpipe.dev/node/v0.2.json",
  "id": "com.cpipe.output.heif_hdr_pq",
  "version": "1.0.0",
  "label": "HEIF HDR PQ Output",
  "category": "output",
  "doc": "Writes display-referred BT.2020 PQ top-aligned RGBA10 input as HDR HEIF.",
  "ports": [
    {
      "name": "rgb",
      "kind": "in",
      "caps": {
        "buffer_kind": "Image2D",
        "channels": ["rgba"],
        "precision": ["u16"]
      },
      "cardinality": "single",
      "metadata": {
        "requires_steps_applied": ["color.scene_linear_to_display"],
        "requires_fields": ["cs_role"]
      }
    }
  ],
  "params": [
    {
      "name": "path",
      "type": "string",
      "required": true
    }
  ],
  "compute": {
    "device": "CPU",
    "engine": "Host",
    "in_pixel_bytes": 8,
    "out_pixel_bytes": 0,
    "scratch_pixel_bytes": 0
  },
  "color": {
    "input_role": "output_pq_rec2020",
    "output_role": "any",
    "respects_chromaticity": true
  }
}
