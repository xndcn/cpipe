{
  "$schema": "https://schemas.cpipe.dev/node/v0.1.json",
  "id": "com.cpipe.wb.dual_illuminant",
  "version": "1.0.0",
  "label": "DNG White Balance",
  "category": "color",
  "doc": "Applies DNG dual-illuminant AsShotNeutral gains and emits the interpolated camera-to-XYZ matrix.",
  "ports": [
    {
      "name": "rgb",
      "kind": "in",
      "caps": {
        "buffer_kind": "Image2D",
        "channels": ["rgba"],
        "precision": ["f16"]
      },
      "cardinality": "single",
      "metadata": {
        "requires_steps_applied": ["demosaic"],
        "requires_fields": [
          "capture.as_shot_neutral",
          "calibration.color_matrix1",
          "calibration.color_matrix2",
          "calibration.calibration_illuminant1",
          "calibration.calibration_illuminant2"
        ]
      }
    },
    {
      "name": "rgb",
      "kind": "out",
      "caps": {
        "buffer_kind": "Image2D",
        "channels": ["rgba"],
        "precision": ["f16"]
      },
      "cardinality": "single",
      "metadata": {
        "inherits_from": "rgb",
        "sets_steps_applied": ["white_balance"]
      }
    }
  ],
  "params": [],
  "compute": {
    "device": "CPU",
    "engine": "Halide",
    "in_pixel_bytes": 8,
    "out_pixel_bytes": 8,
    "scratch_pixel_bytes": 0,
    "halide_aot": ["wb_dual_illuminant"]
  },
  "color": {
    "input_role": "raw_camera",
    "output_role": "raw_camera",
    "respects_chromaticity": true
  }
}
