{
  "$schema": "https://schemas.cpipe.dev/node/v0.2.json",
  "id": "com.cpipe.color.3d_lut",
  "version": "1.0.0",
  "label": "3D LUT",
  "category": "color",
  "doc": "Scene-linear RGB 3D LUT apply with tetrahedral interpolation.",
  "ports": [
    {
      "name": "rgb",
      "kind": "in",
      "caps": {
        "buffer_kind": "Image2D",
        "channels": ["rgba"],
        "precision": ["f16"]
      },
      "cardinality": "single"
    },
    {
      "name": "rgb",
      "kind": "out",
      "caps": {
        "buffer_kind": "Image2D",
        "channels": ["rgba"],
        "precision": ["f16"]
      },
      "cardinality": "single",
      "metadata": {
        "inherits_from": "rgb",
        "sets_steps_applied": ["color.3d_lut"]
      }
    }
  ],
  "params": [
    {
      "name": "lut_path",
      "type": "string"
    },
    {
      "name": "interpolation",
      "type": "enum",
      "enum_values": ["tetrahedral", "trilinear"],
      "default": "tetrahedral"
    }
  ],
  "compute": {
    "device": "CPU",
    "engine": "Halide",
    "in_pixel_bytes": 8,
    "out_pixel_bytes": 8,
    "scratch_pixel_bytes": 0,
    "halide_aot": ["color_3d_lut"]
  },
  "color": {
    "input_role": "scene_linear_rec2020",
    "output_role": "scene_linear_rec2020",
    "respects_chromaticity": false
  }
}
