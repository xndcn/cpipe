Checks: >
  -*,
  readability-*,
  modernize-*,
  cppcoreguidelines-*,
  bugprone-*,
  performance-*,
  portability-*,
  -fuchsia-*,
  -llvm-*,
  -google-readability-todo,
  -modernize-use-trailing-return-type,
  -cppcoreguidelines-avoid-magic-numbers,
  -readability-magic-numbers
HeaderFilterRegex: '(.*/)?(include|src|tests)/cpipe/.*|(.*/)?tests/.*'
WarningsAsErrors: '*'
FormatStyle: file
