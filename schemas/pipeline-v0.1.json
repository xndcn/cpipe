{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.cpipe.dev/pipeline/v0.1.json",
  "type": "object",
  "required": ["version", "id", "input", "nodes", "edges"],
  "additionalProperties": false,
  "properties": {
    "$schema": { "type": "string" },
    "version": { "const": "0.1" },
    "id": { "type": "string", "minLength": 1 },
    "input": {
      "type": "object",
      "required": ["kind", "format", "width", "height"],
      "additionalProperties": false,
      "properties": {
        "kind": { "const": "Image2D" },
        "format": { "const": "R8G8B8A8_UNORM" },
        "width": { "type": "integer", "minimum": 1 },
        "height": { "type": "integer", "minimum": 1 }
      }
    },
    "nodes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "type", "params"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "type": { "type": "string", "pattern": "^com\\.cpipe\\." },
          "params": { "type": "object" }
        }
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["from", "to"],
        "additionalProperties": false,
        "properties": {
          "from": { "type": "string", "pattern": "^[^.]+\\.[^.]+$" },
          "to": { "type": "string", "pattern": "^[^.]+\\.[^.]+$" }
        }
      }
    }
  }
}
