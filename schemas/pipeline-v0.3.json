{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.cpipe.dev/pipeline/v0.3.json",
  "type": "object",
  "required": ["version", "id", "inputs", "nodes", "edges"],
  "additionalProperties": false,
  "properties": {
    "$schema": { "type": "string" },
    "version": { "const": "0.3" },
    "id": { "type": "string", "minLength": 1 },
    "inputs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["port", "kind", "format"],
        "additionalProperties": false,
        "properties": {
          "port": { "type": "string", "minLength": 1 },
          "kind": { "const": "Image2D" },
          "format": {
            "enum": [
              "R8G8B8A8_UNORM",
              "R16_UINT",
              "R32_SFLOAT",
              "R16G16B16A16_SFLOAT",
              "R16G16B16A16_UNORM"
            ]
          },
          "width": { "type": "integer", "minimum": 1 },
          "height": { "type": "integer", "minimum": 1 }
        }
      }
    },
    "nodes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "type", "params"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "type": { "type": "string", "pattern": "^com\\.cpipe\\." },
          "params": { "type": "object" }
        },
        "allOf": [
          {
            "if": {
              "properties": {
                "type": { "const": "com.cpipe.color.scene_linear_to_display" }
              },
              "required": ["type"]
            },
            "then": {
              "properties": {
                "params": {
                  "type": "object",
                  "required": ["target"],
                  "additionalProperties": false,
                  "properties": {
                    "target": {
                      "enum": ["sRGB", "BT2020-PQ", "DisplayP3", "BT2020-HLG"]
                    }
                  }
                }
              }
            }
          },
          {
            "if": {
              "properties": {
                "type": { "const": "com.cpipe.color.3d_lut" }
              },
              "required": ["type"]
            },
            "then": {
              "properties": {
                "params": {
                  "type": "object",
                  "required": ["lut_path"],
                  "additionalProperties": false,
                  "properties": {
                    "lut_path": { "type": "string", "minLength": 1 }
                  }
                }
              }
            }
          },
          {
            "if": {
              "properties": {
                "type": { "const": "com.cpipe.denoise.bm3d" }
              },
              "required": ["type"]
            },
            "then": {
              "properties": {
                "params": {
                  "type": "object",
                  "additionalProperties": false,
                  "properties": {
                    "sigma_override": { "type": "number", "minimum": 0 }
                  }
                }
              }
            }
          }
        ]
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["from", "to"],
        "additionalProperties": false,
        "properties": {
          "from": { "type": "string", "pattern": "^[^.]+\\.[^.]+$" },
          "to": { "type": "string", "pattern": "^[^.]+\\.[^.]+$" }
        }
      }
    }
  }
}
