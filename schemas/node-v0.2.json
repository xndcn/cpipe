{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.cpipe.dev/node/v0.2.json",
  "oneOf": [
    {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "$schema",
        "id",
        "version",
        "label",
        "category",
        "doc",
        "ports",
        "implementations"
      ],
      "properties": {
        "$schema": {
          "const": "https://schemas.cpipe.dev/node/v0.1.json"
        },
        "id": {
          "type": "string",
          "pattern": "^com\\.cpipe\\.[a-z0-9_.-]+$"
        },
        "version": {
          "type": "string"
        },
        "label": {
          "type": "string"
        },
        "category": {
          "type": "string"
        },
        "doc": {
          "type": "string"
        },
        "ports": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "kind", "caps", "cardinality"],
            "properties": {
              "name": {
                "type": "string"
              },
              "kind": {
                "enum": ["in", "out"]
              },
              "caps": {
                "type": "object"
              },
              "cardinality": {
                "enum": ["single", "array"]
              }
            }
          }
        },
        "implementations": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["device", "backend", "aot_id"],
            "properties": {
              "device": {
                "type": "string"
              },
              "backend": {
                "const": "halide_aot"
              },
              "aot_id": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "$schema",
        "id",
        "version",
        "label",
        "category",
        "doc",
        "ports",
        "compute",
        "color"
      ],
      "properties": {
        "$schema": {
          "const": "https://schemas.cpipe.dev/node/v0.2.json"
        },
        "id": {
          "type": "string",
          "pattern": "^com\\.cpipe\\.[a-z0-9_.-]+$"
        },
        "version": {
          "type": "string"
        },
        "label": {
          "type": "string"
        },
        "category": {
          "type": "string"
        },
        "doc": {
          "type": "string"
        },
        "ports": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "kind", "caps", "precision", "cardinality"],
            "properties": {
              "name": {
                "type": "string",
                "pattern": "^[a-z][a-z0-9_]*$"
              },
              "kind": {
                "enum": ["in", "out"]
              },
              "caps": {
                "type": "object",
                "additionalProperties": false,
                "required": ["buffer_kind", "formats"],
                "properties": {
                  "buffer_kind": {
                    "enum": ["Image2D", "Volume3D", "TensorND", "Blob"]
                  },
                  "formats": {
                    "type": "array",
                    "minItems": 1,
                    "items": {
                      "enum": [
                        "R16_UINT",
                        "R10_PACKED",
                        "R8G8B8A8_UNORM",
                        "R8G8B8_UNORM",
                        "R10G10B10A2_UNORM",
                        "R16G16B16A16_SFLOAT",
                        "R16G16B16_SFLOAT",
                        "R16_SFLOAT",
                        "R32G32B32A32_SFLOAT",
                        "R32G32B32_SFLOAT",
                        "R32_SFLOAT",
                        "F16",
                        "F32",
                        "I8",
                        "U8",
                        "BLOB"
                      ]
                    },
                    "uniqueItems": true
                  }
                }
              },
              "precision": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "enum": [
                    "r16_uint",
                    "r16_sfloat",
                    "rgba16_sfloat",
                    "rgba8_unorm",
                    "blob"
                  ]
                },
                "uniqueItems": true
              },
              "cardinality": {
                "enum": ["single", "array"]
              }
            }
          }
        },
        "params": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "compute": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "device",
            "engine",
            "precision",
            "in_pixel_bytes",
            "out_pixel_bytes",
            "scratch_pixel_bytes"
          ],
          "properties": {
            "device": {
              "enum": ["CPU", "Vulkan", "Metal", "Hexagon", "NPU", "AppleNeuralEngine"]
            },
            "engine": {
              "enum": ["Halide", "Slang", "Inference", "C++"]
            },
            "precision": {
              "enum": ["r16_uint", "r16_sfloat", "rgba16_sfloat", "rgba8_unorm", "blob"]
            },
            "halide_aot": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "in_pixel_bytes": {
              "type": "integer",
              "minimum": 0
            },
            "out_pixel_bytes": {
              "type": "integer",
              "minimum": 0
            },
            "scratch_pixel_bytes": {
              "type": "integer",
              "minimum": 0
            }
          }
        },
        "color": {
          "type": "object",
          "additionalProperties": false,
          "required": ["input_role", "output_role"],
          "properties": {
            "input_role": {
              "type": "string"
            },
            "output_role": {
              "type": "string"
            },
            "respects_chromaticity": {
              "type": "boolean"
            }
          }
        },
        "test": {
          "type": "object"
        }
      }
    }
  ]
}
