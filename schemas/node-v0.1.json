{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://schemas.cpipe.dev/node/v0.1.json",
    "title": "cpipe node manifest v0.1",
    "type": "object",
    "required": ["$schema", "id", "version", "label", "category", "doc", "ports", "compute", "color"],
    "additionalProperties": false,
    "properties": {
        "$schema": {
            "const": "https://schemas.cpipe.dev/node/v0.1.json"
        },
        "id": {
            "type": "string",
            "pattern": "^com\\.cpipe\\.[a-z0-9][a-z0-9_.-]*$"
        },
        "version": {
            "type": "string",
            "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(?:[-+][0-9A-Za-z.-]+)?$"
        },
        "label": {
            "type": "string",
            "minLength": 1
        },
        "category": {
            "type": "string",
            "minLength": 1
        },
        "doc": {
            "type": "string",
            "minLength": 1
        },
        "ports": {
            "type": "array",
            "minItems": 1,
            "items": {
                "$ref": "#/$defs/port"
            }
        },
        "params": {
            "type": "array",
            "items": {
                "$ref": "#/$defs/param"
            }
        },
        "compute": {
            "$ref": "#/$defs/compute"
        },
        "color": {
            "$ref": "#/$defs/color"
        },
        "test": {
            "$ref": "#/$defs/test"
        }
    },
    "$defs": {
        "port": {
            "type": "object",
            "required": ["name", "kind", "caps", "cardinality"],
            "additionalProperties": false,
            "properties": {
                "name": {
                    "type": "string",
                    "minLength": 1
                },
                "kind": {
                    "enum": ["in", "out"]
                },
                "caps": {
                    "$ref": "#/$defs/caps"
                },
                "cardinality": {
                    "enum": ["single", "array"]
                }
            }
        },
        "caps": {
            "type": "object",
            "required": ["buffer_kind", "channels", "precision"],
            "additionalProperties": false,
            "properties": {
                "buffer_kind": {
                    "enum": ["Image2D", "Volume3D", "TensorND", "Blob"]
                },
                "formats": {
                    "type": "array",
                    "minItems": 1,
                    "items": {
                        "type": "string",
                        "minLength": 1
                    }
                },
                "channels": {
                    "type": "array",
                    "minItems": 1,
                    "items": {
                        "type": "string",
                        "minLength": 1
                    }
                },
                "precision": {
                    "type": "array",
                    "minItems": 1,
                    "items": {
                        "type": "string",
                        "minLength": 1
                    }
                }
            }
        },
        "param": {
            "type": "object",
            "required": ["name", "type"],
            "additionalProperties": true,
            "properties": {
                "name": {
                    "type": "string",
                    "minLength": 1
                },
                "type": {
                    "enum": ["float", "int", "bool", "enum", "curve", "color"]
                }
            }
        },
        "compute": {
            "type": "object",
            "required": [
                "device",
                "engine",
                "halide_aot",
                "in_pixel_bytes",
                "out_pixel_bytes",
                "scratch_pixel_bytes"
            ],
            "additionalProperties": false,
            "properties": {
                "device": {
                    "enum": ["CPU", "Vulkan", "Metal", "Hexagon", "NPU", "AppleNeuralEngine"]
                },
                "engine": {
                    "enum": ["Halide", "Slang", "Inference"]
                },
                "halide_aot": {
                    "type": "array",
                    "minItems": 1,
                    "items": {
                        "type": "string",
                        "minLength": 1
                    }
                },
                "in_pixel_bytes": {
                    "type": "integer",
                    "minimum": 0
                },
                "out_pixel_bytes": {
                    "type": "integer",
                    "minimum": 0
                },
                "scratch_pixel_bytes": {
                    "type": "integer",
                    "minimum": 0
                }
            }
        },
        "color": {
            "type": "object",
            "required": ["input_role", "output_role", "respects_chromaticity"],
            "additionalProperties": false,
            "properties": {
                "input_role": {
                    "type": "string",
                    "minLength": 1
                },
                "output_role": {
                    "type": "string",
                    "minLength": 1
                },
                "respects_chromaticity": {
                    "type": "boolean"
                }
            }
        },
        "test": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "golden_pairs": {
                    "type": "array",
                    "items": {
                        "type": "object",
                        "required": ["in", "out"],
                        "additionalProperties": false,
                        "properties": {
                            "in": {
                                "type": "string"
                            },
                            "out": {
                                "type": "string"
                            }
                        }
                    }
                },
                "tolerance_psnr_db": {
                    "type": "number"
                },
                "rng_seed": {
                    "type": "integer"
                }
            }
        }
    }
}
